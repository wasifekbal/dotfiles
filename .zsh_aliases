# package manager
alias u="sudo dnf check-update"
alias ug="sudo dnf upgrade"
alias lu="dnf check-update"
alias uu="sudo dnf upgrade --refresh"
alias i="sudo dnf install"
alias s="dnf search"
alias yeet="sudo dnf remove"
alias clean="sudo dnf autoremove && sudo dnf clean all"

# git
alias gss='git status -s'
alias gst='git status'
alias gl='git log --stat'
alias glp='git log --stat -p'
alias glg='git log --graph'
alias glgd='git log --graph --decorate --all'
alias glo='git log --oneline --decorate'
alias gco='git checkout'
alias gd="git diff"
alias gcm="git commit"
alias gad="git add"
alias gpom="git push origin main"

# tmux
alias ta='tmux attach -t'
alias tad='tmux attach -d -t'
alias ts='tmux new-session -s'
alias tl='tmux list-sessions'
alias tksv='tmux kill-server'
alias tkss='tmux kill-session -t'

# misc
alias dkr="docker"
alias py="python"
alias ip="ip -c"
alias open="xdg-open"
alias v="nvim"
alias server="live-server --host=0.0.0.0 --port=5500"
alias dust="du -sh * | sort -hr"
alias sk="screenkey --opacity 0.4 -g \`slop -n -f '%g'\` -p fixed --bak-mode normal"
alias cat='bat --theme "Nord"'
alias q="exit"
alias drag="dragon -a -x"
alias tsmr="transmission-remote"
if [[ "$TERM" = "xterm-kitty" ]]; then
    alias ssh="export TERM=xterm-256color; kitten ssh"
elif [[ "$TERM" = "alacritty" ]]; then
    alias ssh="export TERM=xterm-256color; ssh"
fi
alias r="ranger"

alias l="eza -lh"
alias ll="eza -lah"

alias copy="xclip -selection clipboard"
alias paste="xclip -sel clip -o"
