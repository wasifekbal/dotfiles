#!/bin/bash

# Options
# poweroff='´Çæ Poweroff';
restart_bcompare='´Çí Restart Bcompare';
re_iptux='´Çí Restart Iptux'
re_network="´Çí Restart NetworkManager"
# lock='´Çú Lock';
# suspend='¾░Æ▓ Suspend';
# logout='¾░ìâ Logout';


ROFI_THEME="~/.config/rofi/scripts/powermenu/power.rasi"
SCRIPT_DIR="$HOME/.config/rofi/scripts/tools"

options="$restart_bcompare\n$re_iptux\n$re_network";

choice=$(echo -e $options | rofi -dmenu -p " ´üí " -mesg "Utility Tools" -i -theme $ROFI_THEME);

case "$choice" in
    $restart_bcompare)
        killall -9 BCompare
        nohup bcompare  &> /dev/null &
        ;;
    $re_iptux)
        killall -9 iptux;
        flatpak run io.github.iptux_src.iptux;
        ;;
    $re_network)
        password=$(rofi -dmenu -password -p "Password:" -theme-str 'window { width: 30%; } listview { lines: 1; }');
        echo $password | sudo -S -k systemctl restart NetworkManager;
        ;;
    *) exit 1 ;;
esac


 


